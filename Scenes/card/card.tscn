script/source = "using Godot;

public partial class Card : CanvasLayer
{
	[Signal] public delegate void CardSelectedEventHandler(string upgradeId);

	public override void _Ready()
	{
		 ProcessMode = ProcessModeEnum.Always;
		// Скрываем всё сразу
		CallDeferred(nameof(HideCards));
	}

	private void HideCards()
	{
		var canvas = GetNodeOrNull<Control>(\"CanvasLayer\");
		if (canvas == null) return;

		Control panelLeft = canvas.GetNodeOrNull<Control>(\"Panel\");
		Control panelRight = canvas.GetNodeOrNull<Control>(\"Panel2\");
		Control panelCenter = canvas.GetNodeOrNull<Control>(\"Panel3\");

		if (panelLeft != null) 
		{
			panelLeft.Visible = false;
			panelLeft.Scale = Vector2.Zero;
		}
		if (panelRight != null) 
		{
			panelRight.Visible = false;
			panelRight.Scale = Vector2.Zero;
		}
		if (panelCenter != null) 
		{
			panelCenter.Visible = false;
			panelCenter.Scale = Vector2.Zero;
		}

		// Запускаем таймер на 1 секунду
		var timer = GetTree().CreateTimer(1.0f);
		timer.Timeout += OnTimerTimeout;
	}

	private void OnTimerTimeout()
	{
		var canvas = GetNodeOrNull<Control>(\"CanvasLayer\");
		if (canvas == null) return;

		Control panelLeft = canvas.GetNodeOrNull<Control>(\"Panel\");
		Control panelRight = canvas.GetNodeOrNull<Control>(\"Panel2\");
		Control panelCenter = canvas.GetNodeOrNull<Control>(\"Panel3\");

		if (panelLeft == null || panelRight == null || panelCenter == null) 
		{
			GD.PrintErr(\"Не все панели найдены!\");
			return;
		}

		// Показываем карты
		panelLeft.Visible = true;
		panelRight.Visible = true;
		panelCenter.Visible = true;
		
		// Сбрасываем масштаб
		panelLeft.Scale = Vector2.Zero;
		panelRight.Scale = Vector2.Zero;
		panelCenter.Scale = Vector2.Zero;

		// Запоминаем позиции
		Vector2 posLeft = panelLeft.Position;
		float rotLeft = panelLeft.Rotation;
		
		Vector2 posRight = panelRight.Position;
		float rotRight = panelRight.Rotation;
		
		Vector2 posCenter = panelCenter.Position;

		// Создаем Tween
		var tween = GetTree().CreateTween();
		
		// 1. Первая карта
		tween.TweenProperty(panelLeft, \"scale\", Vector2.One, 0.5f)
			 .SetTrans(Tween.TransitionType.Back).SetEase(Tween.EaseType.Out);
		tween.Parallel().TweenProperty(panelLeft, \"position\", posLeft, 0.5f)
			 .SetTrans(Tween.TransitionType.Back).SetEase(Tween.EaseType.Out);
		tween.Parallel().TweenProperty(panelLeft, \"rotation\", rotLeft, 0.5f)
			 .SetTrans(Tween.TransitionType.Back).SetEase(Tween.EaseType.Out);

		tween.TweenInterval(0.3f);

		// 2. Вторая карта
		tween.Parallel().TweenProperty(panelRight, \"scale\", Vector2.One, 0.5f)
			 .SetTrans(Tween.TransitionType.Back).SetEase(Tween.EaseType.Out);
		tween.Parallel().TweenProperty(panelRight, \"position\", posRight, 0.5f)
			 .SetTrans(Tween.TransitionType.Back).SetEase(Tween.EaseType.Out);
		tween.Parallel().TweenProperty(panelRight, \"rotation\", rotRight, 0.5f)
			 .SetTrans(Tween.TransitionType.Back).SetEase(Tween.EaseType.Out);

		tween.TweenInterval(0.3f);

		// 3. Третья карта
		tween.Parallel().TweenProperty(panelCenter, \"scale\", Vector2.One, 0.5f)
			 .SetTrans(Tween.TransitionType.Back).SetEase(Tween.EaseType.Out);
		tween.Parallel().TweenProperty(panelCenter, \"position\", posCenter, 0.5f)
			 .SetTrans(Tween.TransitionType.Back).SetEase(Tween.EaseType.Out);
		
		GD.Print(\"[Card] Анимация завершена!\");
	}
}
"

